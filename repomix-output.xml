      const zmanimJson = await getZmanimJson(options); // <--- כאן השינוי העיקרי
      setZmanim(zmanimJson.BasicZmanim);
      console.log({zmanim});

    };

    fetchZmanim();
  }, []);

  if (!zmanim) return <p>טוען זמני יום...</p>;

  return (
    <div style={{
      backgroundColor: '#f9f9f9',
      borderRadius: '12px',
      padding: '1rem',
      maxWidth: '450px',
      margin: '2rem auto',
      boxShadow: '0 0 10px rgba(0,0,0,0.1)',
      textAlign: 'right',
      direction: 'rtl',
