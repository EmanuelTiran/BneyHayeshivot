            style={{ opacity: isButtonTransparent ? 0 : 1 }}
          >
            ערוך זמני תפילה והודעות
          </button>
        )}
      </div>

      {/* ══════════════════════ מודאל עריכה ══════════════════════ */}
      {isModalOpen && (
