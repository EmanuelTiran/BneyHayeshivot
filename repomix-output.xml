require('dotenv').config();

const app = express();
connectDB();

app.use(cors({
    origin: [
        'http://localhost:5173', // בשביל הפיתוח (Vite)
        'https://bneyhayeshivot.onrender.com', // הכתובת של האתר שלך ב-Render
