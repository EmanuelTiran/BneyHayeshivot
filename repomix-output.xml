import { useState, useCallback } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { ChevronLeft, ChevronRight, Edit3, X, Plus, Trash2, Save, Image as ImageIcon, AlignLeft, Type } from "lucide-react";
import { Dialog } from "@headlessui/react";
import { useAuth } from '../components/context/authContext';

// --- MOCK AUTH (remove when using real hook) ---
// const useAuth = () => ({ isAdmin: true });
// const { isAdmin } = useAuth();
const normalizeImageUrl = (url) => {
    if (!url) return url;

    if (url.includes("drive.google.com")) {
        const fileId =
            url.match(/\/d\/(.*?)\//)?.[1] ||
            url.match(/id=(.*?)(?:&|$)/)?.[1];

        if (fileId) {
            return `https://lh3.googleusercontent.com/d/${fileId}`;
        }
    }

    return url;
};
// --- MOCK DATA ---
const INITIAL_IMAGES = [
    {
        id: 1,
        imageUrl: "https://drive.google.com/file/d/1fRlOqbhDjK7KQ9_WRlezJbajFnlpqaXo/view?usp=sharing",
        title: "הניסיון שלי",
        description: "Where the air is thin and every breath is earned. A moment suspended between earth and sky.",
    },
    {
        id: 2,
        imageUrl: "https://images.unsplash.com/photo-1501854140801-50d01698950b?w=600&q=80",
        title: "Verdant Depths",
        description: "Ancient canopies filtering light into cathedral green. The forest breathes, and so do you.",
    },
    {
        id: 3,
        imageUrl: "https://images.unsplash.com/photo-1518020382113-a7e8fc38eac9?w=600&q=80",
        title: "Coastal Reverie",
        description: "Salt-laced winds carry stories from distant shores. Stand here long enough, and you will hear them.",
    },
    {
        id: 4,
        imageUrl: "https://images.unsplash.com/photo-1470770903676-69b98201ea1c?w=600&q=80",
        title: "Desert Embers",
        description: "The last light bleeds gold across the sand. Nothing survives the dusk unchanged.",
    },
];

// --- ANIMATION VARIANTS ---
const slideVariants = {
    enter: (dir) => ({
        x: dir > 0 ? "60%" : "-60%",
        opacity: 0,
        scale: 0.96,
    }),
    center: {
        x: 0,
        opacity: 1,
        scale: 1,
        transition: { duration: 0.55, ease: [0.32, 0.72, 0, 1] },
    },
    exit: (dir) => ({
        x: dir > 0 ? "-60%" : "60%",
        opacity: 0,
        scale: 0.96,
        transition: { duration: 0.45, ease: [0.32, 0.72, 0, 1] },
    }),
};

const captionVariants = {
    hidden: { opacity: 0, y: 18 },
    visible: { opacity: 1, y: 0, transition: { duration: 0.5, delay: 0.25, ease: "easeOut" } },
    exit: { opacity: 0, y: -10, transition: { duration: 0.25 } },
};

const modalVariants = {
    hidden: { opacity: 0, scale: 0.97, y: 16 },
    visible: { opacity: 1, scale: 1, y: 0, transition: { duration: 0.35, ease: [0.32, 0.72, 0, 1] } },
    exit: { opacity: 0, scale: 0.97, y: 16, transition: { duration: 0.25 } },
};

// ─────────────────────────────────────────────
// ADMIN MODAL
// ─────────────────────────────────────────────
function AdminModal({ isOpen, onClose, images, setImages }) {
    const [editingId, setEditingId] = useState(null);
    const [form, setForm] = useState({ imageUrl: "", title: "", description: "" });
    const [mode, setMode] = useState("list"); // 'list' | 'edit' | 'add'

    const openAdd = () => {
        setForm({ imageUrl: "", title: "", description: "" });
        setEditingId(null);
        setMode("add");
    };

    const openEdit = (img) => {
        setForm({ imageUrl: img.imageUrl, title: img.title, description: img.description });
        setEditingId(img.id);
        setMode("edit");
    };

    const handleDelete = (id) => {
        setImages((prev) => prev.filter((img) => img.id !== id));
    };

    const handleSave = () => {
        if (!form.title.trim() || !form.imageUrl.trim()) return;
        if (mode === "add") {
            setImages((prev) => [
                ...prev,
                {
                    id: Date.now(), ...form,
                    imageUrl: normalizeImageUrl(form.imageUrl),
                },
            ]);
        } else {
            setImages((prev) =>
                prev.map((img) =>
                    img.id === editingId
                        ? { ...img, ...form, imageUrl: normalizeImageUrl(form.imageUrl) }
                        : img
                ));
        }
        setMode("list");
    };

    const handleClose = () => {
        setMode("list");
        onClose();
    };

    return (
        <Dialog open={isOpen} onClose={handleClose} className="relative z-50">
            {/* Backdrop */}
            <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="fixed inset-0 bg-black/70 backdrop-blur-sm"
                aria-hidden="true"
            />

            <div className="fixed inset-0 flex items-center justify-center p-4">
                <AnimatePresence mode="wait">
                    <motion.div
                        key="modal"
                        variants={modalVariants}
                        initial="hidden"
                        animate="visible"
                        exit="exit"
                    >
                        <Dialog.Panel
                            className="relative w-full max-w-2xl rounded-2xl overflow-hidden shadow-2xl"
                            style={{
                                background: "linear-gradient(145deg, #0f0f13 0%, #17171f 100%)",
                                border: "1px solid rgba(255,255,255,0.08)",
                            }}
                        >
                            {/* Modal Header */}
                            <div className="flex items-center justify-between px-7 py-5 border-b border-white/[0.07]">
                                <div>
                                    <Dialog.Title className="text-lg font-semibold text-white tracking-tight">
                                        {mode === "list" ? "Gallery Manager" : mode === "add" ? "Add New Image" : "Edit Image"}
                                    </Dialog.Title>
                                    <p className="text-xs text-white/40 mt-0.5">
                                        {mode === "list" ? `${images.length} item${images.length !== 1 ? "s" : ""} in gallery` : "Fill in the details below"}
                                    </p>
                                </div>
                                <button
                                    onClick={handleClose}
                                    className="p-2 rounded-lg text-white/40 hover:text-white hover:bg-white/10 transition-all"
                                >
                                    <X size={18} />
                                </button>
                            </div>

                            {/* Modal Body */}
                            <div className="p-7 max-h-[70vh] overflow-y-auto custom-scroll">
                                <AnimatePresence mode="wait">
                                    {mode === "list" ? (
                                        <motion.div
                                            key="list"
                                            initial={{ opacity: 0, x: -20 }}
                                            animate={{ opacity: 1, x: 0 }}
                                            exit={{ opacity: 0, x: 20 }}
                                            transition={{ duration: 0.25 }}
                                        >
                                            <div className="space-y-3 mb-5">
                                                {images.map((img) => (
                                                    <div
                                                        key={img.id}
                                                        className="flex items-center gap-4 p-3 rounded-xl bg-white/[0.04] border border-white/[0.06] group hover:border-white/20 transition-all"
                                                    >
                                                        <div className="w-12 h-12 rounded-lg overflow-hidden flex-shrink-0 bg-white/10">
                                                            <img
                                                                src={img.imageUrl}
                                                                alt={img.title}
                                                                className="w-full h-full object-cover"
                                                                onError={(e) => { e.target.style.display = 'none'; }}
                                                            />
                                                        </div>
                                                        <div className="flex-1 min-w-0">
                                                            <p className="text-sm font-medium text-white truncate">{img.title}</p>
                                                            <p className="text-xs text-white/40 truncate mt-0.5">{img.description}</p>
                                                        </div>
                                                        <div className="flex gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
                                                            <button
                                                                onClick={() => openEdit(img)}
                                                                className="p-1.5 rounded-lg text-white/50 hover:text-amber-400 hover:bg-amber-400/10 transition-all"
                                                            >
                                                                <Edit3 size={14} />
                                                            </button>
                                                            <button
                                                                onClick={() => handleDelete(img.id)}
                                                                className="p-1.5 rounded-lg text-white/50 hover:text-rose-400 hover:bg-rose-400/10 transition-all"
                                                            >
                                                                <Trash2 size={14} />
                                                            </button>
                                                        </div>
                                                    </div>
                                                ))}
                                                {images.length === 0 && (
                                                    <div className="text-center py-10 text-white/30">
                                                        <ImageIcon size={32} className="mx-auto mb-3 opacity-50" />
                                                        <p className="text-sm">No images yet. Add one below.</p>
                                                    </div>
                                                )}
                                            </div>
                                            <button
                                                onClick={openAdd}
                                                className="w-full flex items-center justify-center gap-2 py-3 rounded-xl border border-dashed border-white/20 text-white/50 hover:text-white hover:border-white/40 hover:bg-white/[0.04] transition-all text-sm font-medium"
                                            >
                                                <Plus size={16} />
                                                Add New Image
                                            </button>
                                        </motion.div>
                                    ) : (
                                        <motion.div
                                            key="form"
                                            initial={{ opacity: 0, x: 20 }}
                                            animate={{ opacity: 1, x: 0 }}
                                            exit={{ opacity: 0, x: -20 }}
                                            transition={{ duration: 0.25 }}
                                            className="space-y-5"
                                        >
                                            {/* URL Field */}
                                            <div>
                                                <label className="flex items-center gap-2 text-xs font-medium text-white/50 mb-2 uppercase tracking-wider">
                                                    <ImageIcon size={12} /> Image URL
                                                </label>
                                                <input
                                                    type="text"
                                                    value={form.imageUrl}
                                                    onChange={(e) => setForm((f) => ({ ...f, imageUrl: e.target.value }))}
                                                    placeholder="https://example.com/image.jpg"
                                                    className="w-full px-4 py-3 rounded-xl bg-white/[0.06] border border-white/10 text-white text-sm placeholder-white/25 focus:outline-none focus:border-amber-400/60 focus:bg-white/[0.08] transition-all"
                                                />
                                                {form.imageUrl && (
                                                    <div className="mt-2 h-24 rounded-lg overflow-hidden bg-white/5">
                                                        <img src={normalizeImageUrl(form.imageUrl)} alt="preview" className="w-full h-full object-cover" onError={(e) => { e.target.style.display = "none"; }} />
                                                    </div>
                                                )}
                                            </div>

                                            {/* Title Field */}
                                            <div>
                                                <label className="flex items-center gap-2 text-xs font-medium text-white/50 mb-2 uppercase tracking-wider">
                                                    <Type size={12} /> Title
                                                </label>
                                                <input
                                                    type="text"
                                                    value={form.title}
                                                    onChange={(e) => setForm((f) => ({ ...f, title: e.target.value }))}
                                                    placeholder="Image title"
                                                    className="w-full px-4 py-3 rounded-xl bg-white/[0.06] border border-white/10 text-white text-sm placeholder-white/25 focus:outline-none focus:border-amber-400/60 focus:bg-white/[0.08] transition-all"
                                                />
                                            </div>

                                            {/* Description Field */}
                                            <div>
                                                <label className="flex items-center gap-2 text-xs font-medium text-white/50 mb-2 uppercase tracking-wider">
                                                    <AlignLeft size={12} /> Description
                                                </label>
                                                <textarea
                                                    value={form.description}
                                                    onChange={(e) => setForm((f) => ({ ...f, description: e.target.value }))}
                                                    placeholder="A short description..."
                                                    rows={3}
                                                    className="w-full px-4 py-3 rounded-xl bg-white/[0.06] border border-white/10 text-white text-sm placeholder-white/25 focus:outline-none focus:border-amber-400/60 focus:bg-white/[0.08] transition-all resize-none"
                                                />
                                            </div>

                                            {/* Actions */}
                                            <div className="flex gap-3 pt-2">
                                                <button
                                                    onClick={() => setMode("list")}
                                                    className="flex-1 py-3 rounded-xl border border-white/10 text-white/60 hover:text-white hover:border-white/30 transition-all text-sm font-medium"
                                                >
                                                    Cancel
                                                </button>
                                                <button
                                                    onClick={handleSave}
                                                    disabled={!form.title.trim() || !form.imageUrl.trim()}
                                                    className="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl bg-amber-400 text-black font-semibold text-sm hover:bg-amber-300 disabled:opacity-40 disabled:cursor-not-allowed transition-all"
                                                >
                                                    <Save size={15} />
                                                    Save
                                                </button>
                                            </div>
                                        </motion.div>
                                    )}
                                </AnimatePresence>
                            </div>
                        </Dialog.Panel>
                    </motion.div>
                </AnimatePresence>
            </div>
        </Dialog>
    );
}

// ─────────────────────────────────────────────
// MAIN COMPONENT
// ─────────────────────────────────────────────
export default function ImageGallery() {
    const { isAdmin } = useAuth();

    const [images, setImages] = useState(INITIAL_IMAGES);
    const [index, setIndex] = useState(0);
    const [direction, setDirection] = useState(1);
    const [isHovered, setIsHovered] = useState(false);
    const [isModalOpen, setIsModalOpen] = useState(false);

    const current = images[Math.min(index, images.length - 1)];

    const go = useCallback(
        (dir) => {
            if (images.length <= 1) return;
            setDirection(dir);
            setIndex((i) => (i + dir + images.length) % images.length);
        },
        [images.length]
    );

    if (!images.length) {
        return (
            <div className="flex flex-col items-center justify-center h-64 rounded-2xl bg-neutral-950 border border-white/10 text-white/30">
                <ImageIcon size={36} className="mb-3" />
                <p className="text-sm">Gallery is empty</p>
                {isAdmin && isAdmin() && (
                    <button
                        onClick={() => setIsModalOpen(true)}
                        className="mt-4 px-4 py-2 rounded-lg bg-amber-400 text-black text-xs font-semibold hover:bg-amber-300 transition-all"
                    >
                        Add Images
                    </button>
                )}
                <AdminModal isOpen={isModalOpen} onClose={() => setIsModalOpen(false)} images={images} setImages={setImages} />
            </div>
        );
    }

    return (
        <>
            {/* Outer shell — responsive, centered */}
            <div className="flex justify-center items-start py-8 px-4 min-h-screen bg-neutral-950">
                <div
                    className="relative w-full max-w-sm select-none"
                    onMouseEnter={() => setIsHovered(true)}
                    onMouseLeave={() => setIsHovered(false)}
                >
                    {/* ── A4 Card ── */}
                    <div className="relative w-full aspect-[210/297] rounded-2xl overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.7)]">
                        {/* Slide */}
                        <AnimatePresence custom={direction} mode="popLayout">
                            <motion.div
                                key={current?.id ?? index}
                                custom={direction}
                                variants={slideVariants}
                                initial="enter"
                                animate="center"
                                exit="exit"
                                className="absolute inset-0"
                            >
                                <img
                                    src={current?.imageUrl}
                                    onError={(e) => {
                                        console.log("IMAGE FAILED:", current?.imageUrl);
                                        e.target.style.display = "none";
                                    }}
                                    alt={current?.title}
                                    className="w-full h-full object-cover"
                                    draggable={false}
                                />
                                {/* Gradient vignette */}
                                <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent" />
                            </motion.div>
                        </AnimatePresence>

                        {/* ── Caption ── */}
                        <AnimatePresence mode="wait">
                            <motion.div
                                key={`caption-${current?.id ?? index}`}
                                variants={captionVariants}
                                initial="hidden"
                                animate="visible"
                                exit="exit"
                                className="absolute bottom-0 left-0 right-0 p-6 z-10"
                            >
                                <p
                                    className="text-xs font-semibold tracking-[0.25em] uppercase mb-1.5"
                                    style={{ color: "#f59e0b" }}
                                >
                                    {String(index + 1).padStart(2, "0")} / {String(images.length).padStart(2, "0")}
                                </p>
                                <h2 className="text-2xl font-bold text-white leading-tight tracking-tight drop-shadow-lg">
                                    {current?.title}
                                </h2>
                                <p className="text-sm text-white/65 mt-1.5 leading-relaxed line-clamp-2">
                                    {current?.description}
                                </p>
                            </motion.div>
                        </AnimatePresence>

                        {/* ── Nav Arrows ── */}
                        {images.length > 1 && (
                            <>
                                <motion.button
                                    onClick={() => go(-1)}
                                    whileTap={{ scale: 0.88 }}
                                    className="absolute left-3 top-1/2 -translate-y-1/2 z-20 p-2 rounded-full bg-black/40 backdrop-blur-md border border-white/10 text-white/80 hover:text-white hover:bg-black/60 transition-all"
                                    aria-label="Previous image"
                                >
                                    <ChevronLeft size={20} strokeWidth={2.5} />
                                </motion.button>
                                <motion.button
                                    onClick={() => go(1)}
                                    whileTap={{ scale: 0.88 }}
                                    className="absolute right-3 top-1/2 -translate-y-1/2 z-20 p-2 rounded-full bg-black/40 backdrop-blur-md border border-white/10 text-white/80 hover:text-white hover:bg-black/60 transition-all"
                                    aria-label="Next image"
                                >
                                    <ChevronRight size={20} strokeWidth={2.5} />
                                </motion.button>
                            </>
                        )}

                        {/* ── Admin Edit Button ── */}
                        {isAdmin && isAdmin() && (
                            <AnimatePresence>
                                {isHovered && (
                                    <motion.button
                                        key="edit-btn"
                                        initial={{ opacity: 0, y: -8, scale: 0.9 }}
                                        animate={{ opacity: 1, y: 0, scale: 1 }}
                                        exit={{ opacity: 0, y: -8, scale: 0.9 }}
                                        transition={{ duration: 0.2 }}
                                        onClick={() => setIsModalOpen(true)}
                                        className="absolute top-4 right-4 z-30 flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-black shadow-lg transition-all"
                                        style={{ background: "#f59e0b" }}
                                        whileHover={{ scale: 1.05 }}
                                        whileTap={{ scale: 0.95 }}
                                    >
                                        <Edit3 size={12} strokeWidth={2.5} />
                                        Edit Gallery
                                    </motion.button>
                                )}
                            </AnimatePresence>
                        )}
                    </div>

                    {/* ── Dot Indicators ── */}
                    {images.length > 1 && (
                        <div className="flex justify-center gap-1.5 mt-5">
                            {images.map((_, i) => (
                                <motion.button
                                    key={i}
                                    onClick={() => { setDirection(i > index ? 1 : -1); setIndex(i); }}
                                    animate={{ width: i === index ? 24 : 8, opacity: i === index ? 1 : 0.35 }}
                                    transition={{ duration: 0.3 }}
                                    className="h-1.5 rounded-full bg-amber-400"
                                    aria-label={`Go to slide ${i + 1}`}
                                />
                            ))}
                        </div>
                    )}
                </div>
            </div>

            {/* ── Admin Modal ── */}
            <AnimatePresence>
                {isModalOpen && (
                    <AdminModal
                        isOpen={isModalOpen}
                        onClose={() => setIsModalOpen(false)}
                        images={images}
                        setImages={(updater) => {
                            setImages(updater);
                            setIndex(0);
                        }}
                    />
                )}
            </AnimatePresence>
        </>
    );
}
