const EMPTY_FORM = {
  itemName:         '',
  contributorName:  '',
  commemoratedName: '',
  amount:           '',
  imageUrl:         '',
  date:             new Date().toISOString().split('T')[0],
};

const STATUS_CONFIG = {
  commemorated: { label: 'הונצח',        bg: '#eaf3de', color: '#3b6d11', border: '#97c459' },
  pending:      { label: 'ממתין לאישור', bg: '#faeeda', color: '#854f0b', border: '#ef9f27' },
